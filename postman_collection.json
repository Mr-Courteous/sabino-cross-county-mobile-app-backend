{
  "info": {
    "name": "Sabino Backend API",
    "description": "Complete API collection for Sabino school management system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@school.com\",\n  \"password\": \"password123\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"phone\": \"+2348012345678\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@school.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Schools",
      "item": [
        {
          "name": "Create School",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Government Secondary School\",\n  \"address\": \"123 Main Street\",\n  \"city\": \"Lagos\",\n  \"state\": \"Lagos\",\n  \"country\": \"Nigeria\",\n  \"phone\": \"+2341234567890\",\n  \"email\": \"school@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/schools",
              "host": ["{{base_url}}"],
              "path": ["api", "schools"]
            }
          }
        },
        {
          "name": "Get My Schools",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/schools",
              "host": ["{{base_url}}"],
              "path": ["api", "schools"]
            }
          }
        }
      ]
    },
    {
      "name": "Academic Years",
      "item": [
        {
          "name": "Create Academic Year",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startYear\": 2024,\n  \"endYear\": 2025,\n  \"isCurrent\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/schools/{{schoolId}}/academic-years",
              "host": ["{{base_url}}"],
              "path": ["api", "schools", "{{schoolId}}", "academic-years"]
            }
          }
        }
      ]
    },
    {
      "name": "Classes",
      "item": [
        {
          "name": "Create Class",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"className\": \"JSS1\",\n  \"formTeacher\": \"Mr. Johnson\",\n  \"capacity\": 50\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/schools/{{schoolId}}/academic-years/{{yearId}}/classes",
              "host": ["{{base_url}}"],
              "path": ["api", "schools", "{{schoolId}}", "academic-years", "{{yearId}}", "classes"]
            }
          }
        }
      ]
    },
    {
      "name": "Students",
      "item": [
        {
          "name": "Create Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"classId\": 1,\n  \"firstName\": \"Chioma\",\n  \"lastName\": \"Okafor\",\n  \"admissionNumber\": \"GSS/2024/001\",\n  \"dateOfBirth\": \"2008-05-15\",\n  \"gender\": \"Female\",\n  \"address\": \"45 Student Lane\",\n  \"phone\": \"+2348012345678\",\n  \"parentName\": \"Mrs. Okafor\",\n  \"parentPhone\": \"+2349876543210\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/schools/{{schoolId}}/students",
              "host": ["{{base_url}}"],
              "path": ["api", "schools", "{{schoolId}}", "students"]
            }
          }
        },
        {
          "name": "Get All Students",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/schools/{{schoolId}}/students",
              "host": ["{{base_url}}"],
              "path": ["api", "schools", "{{schoolId}}", "students"]
            }
          }
        }
      ]
    },
    {
      "name": "Subscriptions",
      "item": [
        {
          "name": "Get Plans",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/subscriptions/plans",
              "host": ["{{base_url}}"],
              "path": ["api", "subscriptions", "plans"]
            }
          }
        },
        {
          "name": "Subscribe to Plan",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planId\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/subscriptions/{{schoolId}}/subscribe",
              "host": ["{{base_url}}"],
              "path": ["api", "subscriptions", "{{schoolId}}", "subscribe"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
