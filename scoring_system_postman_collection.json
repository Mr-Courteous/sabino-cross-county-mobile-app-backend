  "item": [
    {
      "name": "Score Entry",
      "item": [
        {
          "name": "Create Single Score",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": 1,\n  \"subjectId\": 5,\n  \"classId\": 3,\n  \"academicYear\": \"2023/2024\",\n  \"term\": 1,\n  \"ca1Score\": 15,\n  \"ca2Score\": 18,\n  \"ca3Score\": 14,\n  \"ca4Score\": 16,\n  \"examScore\": 35,\n  \"teacherRemark\": \"Excellent performance\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/scores/record",
              "host": ["{{base_url}}"],
              "path": ["api", "scores", "record"]
            }
          }
        },
